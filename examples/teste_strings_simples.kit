# Teste Simples de Strings - KitCode v6.0

diga "=== TESTE DE STRINGS ==="

# Criar texto
texto nome "Maria"
diga_texto nome

# Tamanho
tamanho tam nome
diga "Tamanho: " tam

# Juntar
texto saudacao "Oi "
texto completo ""
juntar completo saudacao nome
diga_texto completo

# Maiúscula
texto maiusculo ""
maiuscula maiusculo nome
diga_texto maiusculo

diga "=== FIM ==="
