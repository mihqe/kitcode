# Calculadora Simples em KitCode
diga "=== CALCULADORA KITCODE ==="
diga ""
pergunta "Digite o primeiro numero: " num1
pergunta "Digite o segundo numero: " num2
diga ""
diga "Resultados:"
calc resultado_soma num1 + num2
diga "Soma: " resultado_soma
calc resultado_sub num1 - num2  
diga "Subtracao: " resultado_sub
calc resultado_mult num1 * num2
diga "Multiplicacao: " resultado_mult
calc resultado_div num1 / num2
diga "Divisao: " resultado_div
diga ""
diga "=== FIM ==="